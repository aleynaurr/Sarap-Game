theme_override_font_sizes/font_size = 13
text = "HOW TO PLAY - KUSINA MAMA\n\nMOVEMENT:\n  W / A / S / D  —  Walk around the kitchen\n\nINTERACT:\n  E  —  Enter a cooking station when prompted\n\nIN MINIGAMES:\n  W/A/S/D  —  Direction controls (heat, mixing)\n  SPACE or E  —  Action button (chop, crack, flip)\n  1 / 2 / 3  —  Select zone (plating minigame)\n\nGOAL:\n  Complete all recipe steps before time runs out!\n  Each step is scored on SKILL + SPEED.\n  Earn stars and a grade: S / A / B / C / D\n\nRECIPES:\n  • Tortang Talong   • Lumpiang Shanghai\n  • Sinigang na Baboy   • Kaldereta   • Halo-Halo"
autowrap_mode = 3

