theme_override_font_sizes/font_size = 13
text = "HOW TO PLAY - KUSINA MAMA

MOVEMENT:
  W / A / S / D  —  Walk around the kitchen

INTERACT:
  E  —  Enter a cooking station when prompted

IN MINIGAMES:
  W/A/S/D  —  Direction controls (heat, mixing)
  SPACE or E  —  Action button (chop, crack, flip)
  1 / 2 / 3  —  Select zone (plating minigame)

GOAL:
  Complete all recipe steps before time runs out!
  Each step is scored on SKILL + SPEED.
  Earn stars and a grade: S / A / B / C / D

RECIPES:
  • Tortang Talong   • Lumpiang Shanghai
  • Sinigang na Baboy   • Kaldereta   • Halo-Halo"
autowrap_mode = 3

